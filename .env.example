# Backend environment variables
# Copy this file to .env and fill in the values.

SERVER_HOST=127.0.0.1
SERVER_PORT=3000

# PostgreSQL credentials -- used by the postgres container and to build DATABASE_URL.
# When deploying with docker-compose, use "postgres" as the host in DATABASE_URL.
# For local development outside Docker, use "localhost".
POSTGRES_USER=user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=dnd_db
DATABASE_URL=postgres://user:CHANGE_ME@postgres:5432/dnd_db

REDIS_URL=redis://redis:6379

# REQUIRED: generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME
AUTH_SECRET=CHANGE_ME

MOUSE_THROTTLE_MS=25

ALLOWED_ORIGIN=http://localhost:8080
RUST_LOG=dnd_back=info,tower_http=info
